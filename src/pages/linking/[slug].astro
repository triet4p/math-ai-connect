---
import { getCollection, getEntry, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { globalMdxComponents } from '../../components/mdx-components';

export async function getStaticPaths() {
  const entries = await getCollection('linking', ({ data }) => data.draft !== true);
  return entries.map((entry) => ({
    params: { slug: entry.id }
  }));
}

const { slug } = Astro.params;
if (!slug) {
  throw new Error('Missing linking slug');
}

const entry = await getEntry('linking', slug);
if (!entry || entry.data.draft === true) {
  throw new Error(`Unknown linking post: ${slug}`);
}

const { Content } = await render(entry);

const [primitiveRefs, researchRefs] = await Promise.all([
  Promise.all(entry.data.primitiveRefs.map((ref) => getEntry('primitives', ref))),
  Promise.all(entry.data.researchRefs.map((ref) => getEntry('research', ref)))
]);

const related = [
  ...primitiveRefs
    .filter(Boolean)
    .map((post) => ({ href: `/primitives/${post!.id}`, title: post!.data.title, kind: 'primitive' as const })),
  ...researchRefs
    .filter(Boolean)
    .map((post) => ({ href: `/research/${post!.id}`, title: post!.data.title, kind: 'research' as const }))
].slice(0, 8);
---

<PostLayout
  title={entry.data.title}
  collection="linking"
  publishedAt={entry.data.publishedAt}
  primitiveRefs={entry.data.primitiveRefs}
  researchRefs={entry.data.researchRefs}
  related={related}
>
  <Content components={globalMdxComponents} />
</PostLayout>
