---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PrimitiveCard from '../../components/PrimitiveCard.astro';

const entries = await getCollection('primitives', ({ data }) => data.draft !== true);
const groupOrder = ['foundation', 'physics', 'geometry', 'theory'] as const;

const groups = groupOrder.map((group) => ({
  group,
  items: entries
    .filter((entry) => entry.data.group === group)
    .sort((a, b) => a.data.title.localeCompare(b.data.title))
}));
---

<BaseLayout title="Primitives | Knowledge Journal">
  <header class="mb-6">
    <h1 class="text-3xl font-semibold text-slate-900">Primitives ({entries.length})</h1>
    <p class="text-slate-600">Core mathematical objects grouped by role.</p>
  </header>

  <div class="space-y-8">
    {groups.map(({ group, items }) => (
      <section>
        <h2 class="mb-3 text-lg font-semibold capitalize text-slate-800">{group}</h2>
        <div class="grid gap-3 sm:grid-cols-2">
          {items.map((item) => (
            <PrimitiveCard item={item} />
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>
