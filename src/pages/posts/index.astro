---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getCollection('posts', ({ data }) => data.draft !== true);
posts.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const plannedTopics = await getCollection('plannedTopics', ({ data }) => data.status !== 'done');
const plannedTags = plannedTopics.map((item) => item.data.tag);
const BASE_URL = import.meta.env.BASE_URL;
---

<BaseLayout title="Posts | Knowledge Journal">
  <header class="mb-6">
    <h1 class="text-3xl font-semibold text-slate-900">Posts</h1>
    <p class="text-slate-600">Danh sách ghi chú thống nhất cho toàn bộ dự án.</p>
  </header>

  <section class="mb-6 rounded-md border border-emerald-200 bg-emerald-50 p-4">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <h2 class="text-base font-semibold text-emerald-900">Planned topic tags</h2>
        <p class="text-sm text-emerald-800">Các thẻ/chủ đề đang dự định nghiên cứu để nhắc nhớ trong roadmap cá nhân.</p>
      </div>
      <a class="text-sm font-medium text-emerald-800 hover:text-emerald-900" href={`${BASE_URL}plans`}>Open plans</a>
    </div>

    {plannedTags.length > 0 ? (
      <div class="mt-3 flex flex-wrap gap-2">
        {plannedTags.map((tag) => (
          <span class="rounded-full border border-emerald-300 bg-white px-2 py-0.5 text-xs text-emerald-800">#{tag}</span>
        ))}
      </div>
    ) : (
      <p class="mt-3 text-sm text-emerald-800">Chưa có planned tags.</p>
    )}
  </section>

  <div class="space-y-3">
    {posts.map((post) => (
      <article class="rounded-md border-l-4 border-indigo-600 bg-slate-100 p-4">
        <a class="font-semibold text-slate-900" href={`${BASE_URL}posts/${post.id}`}>{post.data.title}</a>
        <p class="mt-1 text-sm text-slate-600">{post.data.summary}</p>
        <p class="mt-2 text-xs text-slate-500">{post.data.publishedAt.toISOString().slice(0, 10)}</p>
      </article>
    ))}
  </div>
</BaseLayout>
