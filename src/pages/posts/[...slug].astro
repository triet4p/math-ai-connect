---
import { getCollection, getEntry, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { globalMdxComponents } from '../../components/mdx-components';

export async function getStaticPaths() {
  const entries = await getCollection('posts', ({ data }) => data.draft !== true);
  return entries.map((entry) => ({
    params: { slug: entry.id }
  }));
}

const slugParam = Astro.params.slug;
const slug = slugParam;
if (!slug) {
  throw new Error('Missing post slug');
}

const entry = await getEntry('posts', slug);
if (!entry || entry.data.draft === true) {
  throw new Error(`Unknown post: ${slug}`);
}

const { Content } = await render(entry);

const refsEntries = (
  await Promise.all((entry.data.refs ?? []).map((id) => getEntry('posts', id)))
).filter((value): value is NonNullable<typeof value> => Boolean(value));

const BASE_URL = import.meta.env.BASE_URL;
---

<PostLayout
  title={entry.data.title}
  publishedAt={entry.data.publishedAt}
  tags={entry.data.tags ?? []}
>
  <Content components={globalMdxComponents} />

  {refsEntries.length > 0 && (
    <>
      <h2>References</h2>
      <ul>
        {refsEntries.map((ref) => (
          <li>
            <a href={`${BASE_URL}posts/${ref.id}`}>{ref.data.title}</a>
          </li>
        ))}
      </ul>
    </>
  )}
</PostLayout>
