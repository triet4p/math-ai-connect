---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PrimitiveCard from '../components/PrimitiveCard.astro';

const sortByDate = <T extends { data: { publishedAt: Date } }>(a: T, b: T) =>
	b.data.publishedAt.getTime() - a.data.publishedAt.getTime();

const [primitives, research, linking] = await Promise.all([
	getCollection('primitives', ({ data }) => data.draft !== true),
	getCollection('research', ({ data }) => data.draft !== true),
	getCollection('linking', ({ data }) => data.draft !== true)
]);

const latestPrimitives = primitives.sort(sortByDate).slice(0, 3);
const latestResearch = research.sort(sortByDate).slice(0, 3);
const latestLinking = linking.sort(sortByDate).slice(0, 3);
const BASE_URL = import.meta.env.BASE_URL;
---

<BaseLayout title="Knowledge Journal">
	<section class="space-y-2">
		<h1 class="text-3xl font-semibold text-slate-900">Mathematical Primitives → AI Research</h1>
		<p class="text-slate-600">A personal learning journal for connecting first principles to model-building ideas.</p>
	</section>

	<section class="mt-8 space-y-3">
		<div class="flex items-center justify-between">
			<h2 class="text-xl font-semibold">Latest primitives</h2>
			<a href={`${BASE_URL}primitives`} class="text-sm">View all</a>
		</div>
		<div class="space-y-3">
			{latestPrimitives.map((item) => <PrimitiveCard item={item} />)}
		</div>
	</section>

	<section class="mt-10 space-y-3">
		<div class="flex items-center justify-between">
			<h2 class="text-xl font-semibold">Latest research</h2>
			<a href={`${BASE_URL}research`} class="text-sm">View all</a>
		</div>
		<div class="space-y-3">
			{latestResearch.map((item) => (
				<article class="rounded-md border-l-4 border-teal-600 bg-slate-100 p-4">
					<a class="font-semibold text-slate-900" href={`${BASE_URL}research/${item.id}`}>{item.data.title}</a>
					<p class="mt-1 text-xs text-slate-500">{item.data.publishedAt.toISOString().slice(0, 10)} • {item.data.trend}</p>
				</article>
			))}
		</div>
	</section>

	<section class="mt-10 space-y-3">
		<div class="flex items-center justify-between">
			<h2 class="text-xl font-semibold">Latest linking notes</h2>
			<a href={`${BASE_URL}linking`} class="text-sm">View all</a>
		</div>
		<div class="space-y-3">
			{latestLinking.map((item) => (
				<article class="rounded-md border-l-4 border-amber-600 bg-slate-100 p-4">
					<a class="font-semibold text-slate-900" href={`${BASE_URL}linking/${item.id}`}>{item.data.title}</a>
					<p class="mt-1 text-xs text-slate-500">{item.data.publishedAt.toISOString().slice(0, 10)}</p>
				</article>
			))}
		</div>
	</section>
</BaseLayout>
