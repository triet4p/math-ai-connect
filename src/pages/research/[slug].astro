---
import { getCollection, getEntry, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { globalMdxComponents } from '../../components/mdx-components';

export async function getStaticPaths() {
  const entries = await getCollection('research', ({ data }) => data.draft !== true);
  return entries.map((entry) => ({
    params: { slug: entry.id }
  }));
}

const { slug } = Astro.params;
if (!slug) {
  throw new Error('Missing research slug');
}

const entry = await getEntry('research', slug);
if (!entry || entry.data.draft === true) {
  throw new Error(`Unknown research post: ${slug}`);
}

const { Content } = await render(entry);

const [primitiveRefs, linkingPosts] = await Promise.all([
  Promise.all((entry.data.primitiveRefs ?? []).map((ref) => getEntry('primitives', ref))),
  getCollection('linking', ({ data }) => data.draft !== true)
]);

const related = [
  ...primitiveRefs
    .filter(Boolean)
    .map((post) => ({ href: `/primitives/${post!.id}`, title: post!.data.title, kind: 'primitive' as const })),
  ...linkingPosts
    .filter((post) => (post.data.researchRefs ?? []).includes(entry.id))
    .map((post) => ({ href: `/linking/${post.id}`, title: post.data.title, kind: 'linking' as const }))
].slice(0, 8);
---

<PostLayout
  title={entry.data.title}
  collection="research"
  trend={entry.data.trend}
  publishedAt={entry.data.publishedAt}
  primitiveRefs={entry.data.primitiveRefs ?? []}
  related={related}
>
  <Content components={globalMdxComponents} />
</PostLayout>
