---
import '../styles/global.css';
import 'katex/dist/katex.min.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Knowledge Journal',
  description = 'Mathematical primitives, AI research notes, and linking insights.'
} = Astro.props as Props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header class="border-b border-slate-200 bg-slate-100/60">
      <div class="mx-auto flex w-full max-w-[680px] items-center justify-between px-4 py-4">
        <a href="/" class="font-semibold text-slate-900">Knowledge Journal</a>
        <nav class="flex items-center gap-4 text-sm">
          <a href="/primitives">Primitives</a>
          <a href="/research">Research</a>
          <a href="/linking">Linking</a>
          <a href="/graph">Graph</a>
        </nav>
      </div>
    </header>
    <main class="mx-auto w-full max-w-[680px] px-4 py-8">
      <slot />
    </main>
  </body>
</html>
