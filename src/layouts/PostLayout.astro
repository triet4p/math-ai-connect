---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  publishedAt: Date;
  tags?: string[];
}

const {
  title,
  publishedAt,
  tags = []
} = Astro.props as Props;
---

<BaseLayout title={`${title} | Knowledge Journal`}>
  <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_260px]">
    <article class="space-y-6">
      <header class="space-y-3 border-b border-slate-200 pb-4">
        <p class="text-xs uppercase tracking-[0.12em] text-slate-500">Post</p>
        <h1 class="text-3xl font-semibold leading-tight text-slate-900">{title}</h1>
        <div class="flex flex-wrap items-center gap-3 text-sm text-slate-600">
          <span>{publishedAt.toISOString().slice(0, 10)}</span>
          {tags.length > 0 && <span>{tags.join(' • ')}</span>}
        </div>
      </header>

      <div id="post-content" class="prose prose-slate max-w-none">
        <slot />
      </div>
    </article>

    <aside class="hidden lg:block">
      <div class="sticky top-6 flex max-h-[calc(100vh-1.5rem)] flex-col rounded-md border border-slate-200 bg-slate-50 p-4">
        <h2 class="mb-3 text-sm font-semibold uppercase tracking-[0.08em] text-slate-700">Table of Contents</h2>
        <nav id="toc" class="min-h-0 flex-1 overflow-y-auto pr-1 text-sm"></nav>
      </div>
    </aside>
  </div>

  <script>
    const content = document.getElementById('post-content');
    const tocContainer = document.getElementById('toc');

    if (content && tocContainer) {
      const headingSelector = 'h2, h3';
      const headings = Array.from(content.querySelectorAll(headingSelector)) as HTMLHeadingElement[];

      const slugify = (value: string) => value
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9\s-]/g, '')
        .trim()
        .replace(/\s+/g, '-');

      const makeId = (heading: HTMLHeadingElement) => {
        if (heading.id) {
          return heading.id;
        }
        const base = slugify(heading.textContent ?? 'section') || 'section';
        let candidate = base;
        let index = 2;
        while (document.getElementById(candidate)) {
          candidate = `${base}-${index}`;
          index += 1;
        }
        heading.id = candidate;
        return candidate;
      };

      const getLevel = (heading: HTMLHeadingElement) => Number(heading.tagName.slice(1));

      type TocGroup = {
        id: string;
        text: string;
        children: Array<{ id: string; text: string }>;
      };

      const tocGroups: TocGroup[] = [];

      for (const heading of headings) {
        const id = makeId(heading);
        const level = getLevel(heading);
        const text = heading.textContent?.trim() ?? '';

        if (!text) {
          continue;
        }

        if (level === 2) {
          tocGroups.push({ id, text, children: [] });
          continue;
        }

        if (level === 3) {
          const parent = tocGroups[tocGroups.length - 1];
          if (parent) {
            parent.children.push({ id, text });
          } else {
            tocGroups.push({ id, text, children: [] });
          }
        }
      }

      if (tocGroups.length === 0) {
        tocContainer.innerHTML = '<p class="text-slate-500">No sections found.</p>';
      } else {
        const list = document.createElement('ul');
        list.className = 'space-y-2';

        for (let index = 0; index < tocGroups.length; index += 1) {
          const group = tocGroups[index];
          const item = document.createElement('li');

          const row = document.createElement('div');
          row.className = 'flex items-start gap-2';

          const link = document.createElement('a');
          link.href = `#${group.id}`;
          link.className = 'flex-1 text-slate-700 hover:text-slate-900';
          link.textContent = group.text;

          row.appendChild(link);

          if (group.children.length > 0) {
            const childListId = `toc-children-${index}`;
            const toggle = document.createElement('button');
            toggle.type = 'button';
            toggle.className = 'rounded border border-slate-300 px-2 py-0.5 text-[11px] font-medium text-slate-600 hover:bg-slate-100';
            toggle.textContent = 'Collapse';
            toggle.dataset.tocToggle = childListId;
            toggle.setAttribute('aria-controls', childListId);
            toggle.setAttribute('aria-expanded', 'true');
            row.appendChild(toggle);
          }

          item.appendChild(row);

          if (group.children.length > 0) {
            const children = document.createElement('ul');
            children.id = `toc-children-${index}`;
            children.className = 'mt-1 ml-4 space-y-1';

            for (const child of group.children) {
              const childItem = document.createElement('li');
              const childLink = document.createElement('a');
              childLink.href = `#${child.id}`;
              childLink.className = 'text-slate-600 hover:text-slate-900';
              childLink.textContent = child.text;
              childItem.appendChild(childLink);
              children.appendChild(childItem);
            }

            item.appendChild(children);
          }

          list.appendChild(item);
        }

        tocContainer.appendChild(list);

        tocContainer.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof HTMLButtonElement)) {
            return;
          }

          const childListId = target.dataset.tocToggle;
          if (!childListId) {
            return;
          }

          const childList = document.getElementById(childListId);
          if (!childList) {
            return;
          }

          const isCollapsed = childList.classList.toggle('hidden');
          target.textContent = isCollapsed ? 'Show' : 'Collapse';
          target.setAttribute('aria-expanded', String(!isCollapsed));
        });
      }
    }
  </script>
</BaseLayout>
