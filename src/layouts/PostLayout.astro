---
import BaseLayout from './BaseLayout.astro';
import RefsPanel from '../components/RefsPanel.astro';
import RelatedPosts from '../components/RelatedPosts.astro';

type RelatedItem = {
  href: string;
  title: string;
  kind: 'primitive' | 'research' | 'linking';
};

interface Props {
  title: string;
  publishedAt: Date;
  collection: 'primitives' | 'research' | 'linking';
  group?: string;
  trend?: string;
  primitiveRefs?: string[];
  researchRefs?: string[];
  related?: RelatedItem[];
}

const {
  title,
  publishedAt,
  collection,
  group,
  trend,
  primitiveRefs = [],
  researchRefs = [],
  related = []
} = Astro.props as Props;

const metaLine = [group, trend].filter(Boolean).join(' • ');
---

<BaseLayout title={`${title} | Knowledge Journal`}>
  <article class="space-y-6">
    <header class="space-y-3 border-b border-slate-200 pb-4">
      <p class="text-xs uppercase tracking-[0.12em] text-slate-500">{collection}</p>
      <h1 class="text-3xl font-semibold leading-tight text-slate-900">{title}</h1>
      <div class="flex flex-wrap items-center gap-3 text-sm text-slate-600">
        <span>{publishedAt.toISOString().slice(0, 10)}</span>
        {metaLine && <span>{metaLine}</span>}
      </div>
      <div class="lg:hidden">
        <RefsPanel primitiveRefs={primitiveRefs} researchRefs={researchRefs} />
      </div>
    </header>

    <div class="lg:grid lg:grid-cols-[minmax(0,680px)_220px] lg:gap-8">
      <div class="prose prose-slate max-w-none">
        <slot />
      </div>
      <aside class="hidden lg:block">
        <div class="sticky top-6">
          <RefsPanel primitiveRefs={primitiveRefs} researchRefs={researchRefs} />
        </div>
      </aside>
    </div>

    <RelatedPosts items={related} />
  </article>
</BaseLayout>
